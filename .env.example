# LiteLLM
LITELLM_MASTER_KEY=sk-change-this-local-key
PUBLIC_MODEL_NAME=local-main
LITELLM_MODEL=openai/local-main
REQUEST_TIMEOUT_SECONDS=120

# LM Studio
LMSTUDIO_BASE_URL=http://host.docker.internal:1234
LMSTUDIO_OPENAI_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL_ID=local-main

# LiteLLM state
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm
POSTGRES_DB=litellm
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm
REDIS_HOST=redis
REDIS_PORT=6379

# Gateway behavior
ORCHESTRATOR_BASE_URL_PUBLIC=http://localhost:4100
QUEUE_PROXY_API_KEY=
QUEUE_PROXY_CONFIG_PATH=/app/config/orchestrator.yaml
UPSTREAM_LITELLM_BASE_URL=http://litellm:4000
MAX_ACTIVE_REQUESTS=1
MAX_QUEUED_REQUESTS=16
QUEUE_TIMEOUT_SECONDS=30
DEFAULT_MAX_OUTPUT_TOKENS=512
MAX_INPUT_TOKENS=8192
MAX_OUTPUT_TOKENS=1024
MAX_TOTAL_TOKENS=9216

# Healthcheck
LITELLM_BASE_URL=http://litellm:4000
ENABLE_LITELLM_PATH_CHECK=true
READINESS_PROMPT=Return exactly: ok
READINESS_MAX_TOKENS=8

# Observability
ENABLE_PROMPT_LOGGING=false
ENABLE_PROMETHEUS=true
LOG_LEVEL=INFO
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
